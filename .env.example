# নাগরিক-GENESIS Environment Configuration
# Copy this file to .env and fill in your API keys.

# Primary Gemini API Key (required)
GEMINI_API_KEY=your_primary_api_key_here

# Backup API keys for automatic rotation when daily quota is hit (optional)
# GEMINI_BACKUP_KEY_1=your_backup_key_1
# GEMINI_BACKUP_KEY_2=your_backup_key_2
# GEMINI_BACKUP_KEY_3=your_backup_key_3

# Dedicated Summary API Key (optional — separate quota for expert summaries)
# SUMMARY_API_KEY=your_summary_key_here

# Random seed for reproducibility (optional)
# RANDOM_SEED=42
